{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "version": "1.0.1",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "dmarc-report-viewer@precure.tv",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "16": "images/icon.svg",
    "32": "images/icon.svg",
    "48": "images/icon.svg",
    "64": "images/icon.svg",
    "128": "images/icon.svg"
  },
  "permissions": [
    "messagesRead",
    "accountsRead",
    "storage"
  ],
  "background": {
    "scripts": [
      "lib/pako.min.js",
      "lib/jszip.min.js",
      "parser/ar_parser.js",
      "parser/fr_parser.js",
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "__MSG_extensionName__",
    "default_icon": "images/icon.svg"
  },
  "options_ui": {
    "page": "options/options.html"
  },
  "content_security_policy": "script-src 'self'; object-src 'self';"
}
